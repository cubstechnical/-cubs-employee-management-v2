###############################################
# Example environment variables (placeholders) #
###############################################

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Server-only key (DO NOT expose on client)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Admin token for refreshing materialized views (server-only)
REFRESH_VIEWS_TOKEN=YOUR_LONG_RANDOM_TOKEN

# Feature Flags
NEXT_PUBLIC_USE_DOCS_MV=0

# SendGrid Email Configuration
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY
SENDGRID_FROM_EMAIL=you@example.com

# Backblaze B2 Storage Configuration
B2_APPLICATION_KEY_ID=YOUR_B2_KEY_ID
B2_APPLICATION_KEY=YOUR_B2_KEY
B2_BUCKET_NAME=cubsdocs
B2_ENDPOINT=s3.us-east-005.backblazeb2.com
B2_BUCKET_ID=YOUR_B2_BUCKET_ID

# Optional app URL for metadata
NEXT_PUBLIC_APP_URL=https://your-domain.com